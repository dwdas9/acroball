<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:Acroball.UI"
             xmlns:conv="using:Acroball.UI.Converters"
             x:Class="Acroball.UI.App"
             RequestedThemeVariant="Default">

  <Application.DataTemplates>
    <ui:ViewLocator />
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Acroball.UI/Theme/Palette.axaml" />
        <ResourceInclude Source="avares://Acroball.UI/Theme/Tokens.axaml" />
        <ResourceInclude Source="avares://Acroball.UI/Theme/Icons.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <conv:IconKeyToGeometryConverter x:Key="IconKey" />
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Acroball.UI/Theme/Typography.axaml" />
    <StyleInclude Source="avares://Acroball.UI/Theme/Controls.axaml" />
  </Application.Styles>

</Application>

